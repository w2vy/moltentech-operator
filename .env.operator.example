# Operator-side env for docker-compose.operator.yml. Copy to .env.operator on each
# host and fill the subset that host needs (agent vars on the Proxmox box, coalition
# vars beside MT). .env.operator is gitignored — never commit real keys.

# ---- shared ----
MT_BASE_URL=https://staging.moltentech.us
PROVIDER_SLUG=pve25-lab
AGENT_KEY=                       # legacy bearer (operator -> MT); MT admin -> Providers -> Issue keys
# Phase B (preferred): sign agent -> MT with the manifest key instead of AGENT_KEY.
# base64 of the manifest-key.pem from `mt-manifest keygen` (the key whose pubkey MT
# pinned as the provider's manifestPubkey). SECRET. When set, AGENT_KEY is optional.
#   MANIFEST_KEY=$(base64 -w0 manifest-key.pem)
MANIFEST_KEY=

# Phase C: self-pinned owner Flux/ZelID address. When set, the agent refuses
# privileged jobs (delete/reprovision/move) without a matching owner signature.
# ALSO the login-less gate for the operator console (below): the Coalition only
# queues signatures that recover to this address, and the agent re-verifies on
# pickup. Unset = enforcement off. NEVER a value MT gives you.
#   OWNER_ADDRESS=1YourZelIdAddress...   (or t1YourFluxAddress...)
OWNER_ADDRESS=

# ---- agent (runs on the operator's Proxmox box, e.g. pve25) ----
AGENT_DRY_RUN=1                  # 1 = control-plane only (no Proxmox); unset for real provisioning
AGENT_LISTING_JSON=[{"tier":"nimbus","priceCents":2200,"capacity":8,"availableSlots":8}]
PROXMOX_URL=https://127.0.0.1:8006
PROXMOX_TOKEN_ID=mt-agent@pve!agent
PROXMOX_TOKEN_SECRET=
PROXMOX_NETWORK=vmbr0
PROXMOX_STORAGE_IMAGES=local-lvm
PROXMOX_STORAGE_ISO=local
ARCANE_ISO=                      # exact ArcaneOS ISO filename in pve25 'local' storage
OPERATOR_SSH_PUBKEY=
CONSOLE_PASSWORD_HASH=!

# Inventory (WS2): declare your agent-managed hosts + slots to MT so you never
# hand-edit MT's DB. Prefer a local file (editable from the console); the agent
# re-reads it each heartbeat so edits apply without a restart. Falls back to
# inline JSON. Absent = don't declare inventory.
#   AGENT_INVENTORY_PATH=/data/inventory.json
AGENT_INVENTORY_PATH=
# AGENT_INVENTORY_JSON=[{"nodeName":"pve25","apiUrl":"https://pve25:8006","slots":[...]}]

# Owner-authorization courier (WS3): the agent relays owner signatures via YOUR
# Coalition console instead of MT's admin UI. Point this at your Coalition's base
# URL; the agent pushes pending authorizations there and polls for signed blobs.
# Needs MANIFEST_KEY (to auth to the console) + OWNER_ADDRESS. Unset = courier off.
#   COALITION_URL=https://your-coalition.app.runonflux.io
COALITION_URL=

# ---- coalition (runs beside MT for this test, e.g. w2vy) ----
# OWNER_ADDRESS (shared, above) is REQUIRED here too: it's the login-less gate for
# the operator console (/console). Without it the console can't authorize anyone.
COALITION_KEY=                     # MT admin -> Issue keys (MT -> operator); legacy bearer, dual-accept fallback
MT_PUBKEY=                         # global MT ed25519 pubkey (base64) from MT's /api/mt-pubkey; enables signature auth on /checkout+/manage
STRIPE_SECRET_KEY=rk_test_       # restricted TEST key (Checkout/Prices/Subscriptions/Portal only)
STRIPE_WEBHOOK_SECRET=whsec_
TIER_PRICES_JSON={"nimbus":2200}
TRIAL_DAYS=1
MANIFEST_PATH=./manifest.json
PORT=8088
