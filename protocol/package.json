{
  "name": "@moltentech/protocol",
  "version": "0.1.0",
  "description": "Shared wire contracts for the MoltenTech marketplace: Provider Manifest + agent/Coalition JSON messages. Single source of truth imported by the web app, the operator agent, and the operator Coalition.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./signing": {
      "types": "./src/signing.ts",
      "import": "./src/signing.ts",
      "default": "./src/signing.ts"
    },
    "./wallet": {
      "types": "./src/wallet.ts",
      "import": "./src/wallet.ts",
      "default": "./src/wallet.ts"
    },
    "./sign-launcher": {
      "types": "./src/sign-launcher.ts",
      "import": "./src/sign-launcher.ts",
      "default": "./src/sign-launcher.ts"
    }
  },
  "files": ["src"],
  "bin": {
    "mt-manifest": "./src/cli.ts",
    "mt-authorize": "./src/authorize-cli.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/signing.test.ts src/wallet.test.ts src/sign-launcher.test.ts src/manifest-config.test.ts src/manifest.test.ts src/cli-verify.test.ts",
    "manifest": "tsx src/cli.ts"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
